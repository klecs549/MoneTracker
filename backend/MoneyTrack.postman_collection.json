{
  "info": {
    "name": "MoneyTrack API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001" },
    { "key": "token",    "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john\",\n  \"mail\": \"john@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mail\": \"john@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('token', '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/auth/logout"
          }
        },
        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/auth/account"
          }
        }
      ]
    },
    {
      "name": "Tags",
      "item": [
        {
          "name": "List Tags (with spending)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/tags"
          }
        },
        {
          "name": "Create Tag",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{base_url}}/api/tags",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Food\",\n  \"icon\": \"🍔\"\n}"
            }
          }
        },
        {
          "name": "Update Tag",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{base_url}}/api/tags/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Groceries\",\n  \"icon\": \"🛒\"\n}"
            }
          }
        },
        {
          "name": "Delete Tag",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/tags/1"
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/transactions?page=1",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions"],
              "query": [
                { "key": "page",  "value": "1",    "description": "Page number (20 per page)" },
                { "key": "tagId", "value": "",     "description": "Filter by tag id. Use 'none' for untagged.", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create Transaction",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{base_url}}/api/transactions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": -25.50,\n  \"tagId\": null,\n  \"note\": \"Lunch\",\n  \"date\": \"2026-06-10T12:00:00Z\"\n}"
            }
          }
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{base_url}}/api/transactions/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": -30.00,\n  \"note\": \"Dinner\"\n}"
            }
          }
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/transactions/1"
          }
        }
      ]
    },
    {
      "name": "Borrowing",
      "item": [
        {
          "name": "List Borrowings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/borrowing"
          }
        },
        {
          "name": "Create Borrowing",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{base_url}}/api/borrowing",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100.00,\n  \"date\": \"2026-06-10T00:00:00Z\",\n  \"returnDate\": null,\n  \"status\": \"awaiting\"\n}"
            }
          }
        },
        {
          "name": "Update Borrowing",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{base_url}}/api/borrowing/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"returnDate\": \"2026-07-01T00:00:00Z\",\n  \"status\": \"returned\"\n}"
            }
          }
        },
        {
          "name": "Delete Borrowing",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/borrowing/1"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/health"
          }
        }
      ]
    }
  ]
}
